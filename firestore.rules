// Firestore Security Rules
//
// Schema layering:
//   workspaces/{id}    — top-level container; has members[] and acl{uid:role}
//   projects/{id}      — workspaceId field; project-level ACL nested inside a workspace
//   tasks, activities,
//   taskComments,
//   templates, savedViews,
//   webhooks           — workspaceId field; access derived from workspace membership

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(resource) {
      return request.auth != null
          && request.auth.uid == resource.data.userId;
    }
    function isCreatingOwn() {
      return request.auth != null
          && request.auth.uid == request.resource.data.userId;
    }

    // ─── User profile / approval helpers ────────────────────────────────────
    // Hardcoded superadmin emails. Mirrored in src/services/firebase.js so
    // both client and rules agree on who is auto-approved.
    function isSuperadminEmail(email) {
      return email == 'blueinnovation.ph@gmail.com'
          || email == 'aejorango888@gmail.com';
    }
    function isApprovedSuperadmin() {
      return request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin'
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }

    // ─── Workspace helpers ──────────────────────────────────────────────────
    function isWorkspaceMember(workspaceId) {
      return request.auth != null
          && workspaceId is string
          && exists(/databases/$(database)/documents/workspaces/$(workspaceId))
          && request.auth.uid in get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.members;
    }
    function workspaceRole(workspaceId) {
      return request.auth != null
          && workspaceId is string
          && exists(/databases/$(database)/documents/workspaces/$(workspaceId))
          ? get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.acl[request.auth.uid]
          : null;
    }
    function isWorkspaceOwner(workspaceId) { return workspaceRole(workspaceId) == 'owner'; }
    function isWorkspaceAdmin(workspaceId) {
      let r = workspaceRole(workspaceId);
      return r == 'owner' || r == 'admin';
    }
    function canEditWorkspace(workspaceId) {
      let r = workspaceRole(workspaceId);
      return r == 'owner' || r == 'admin' || r == 'editor';
    }

    // ─── Project helpers (per-project ACL inside a workspace) ───────────────
    function isProjectMember(projectId) {
      return request.auth != null
          && projectId is string
          && exists(/databases/$(database)/documents/projects/$(projectId))
          && request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.members;
    }
    function hasProjectRole(projectId, role) {
      return request.auth != null
          && projectId is string
          && exists(/databases/$(database)/documents/projects/$(projectId))
          && get(/databases/$(database)/documents/projects/$(projectId)).data.acl[request.auth.uid] == role;
    }
    function canEditProject(projectId) {
      return hasProjectRole(projectId, 'admin') || hasProjectRole(projectId, 'editor');
    }

    // ─── Workspaces ─────────────────────────────────────────────────────────
    // Helper: a self-update is one where the only fields changed are
    // memberProfiles + updatedAt, AND the only key in memberProfiles that
    // changed is the caller's own UID slot. Used so any workspace member can
    // keep their own display-name slot fresh without admin privileges.
    function isMemberSelfProfileUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let changedProfileKeys = request.resource.data.memberProfiles
        .diff(resource.data.get('memberProfiles', {}))
        .affectedKeys();
      return request.auth != null
          && request.auth.uid in resource.data.members
          && changed.hasOnly(['memberProfiles', 'updatedAt'])
          && changedProfileKeys.hasOnly([request.auth.uid]);
    }

    match /workspaces/{workspaceId} {
      // Anyone in the members array can read the workspace.
      allow read:   if request.auth != null && request.auth.uid in resource.data.members;
      // Anyone signed-in can create their own workspace.
      allow create: if request.auth != null
                    && request.resource.data.createdByUserId == request.auth.uid
                    && request.auth.uid in request.resource.data.members
                    && request.resource.data.acl[request.auth.uid] == 'owner';
      // Updates: owners + admins can mutate anything. Any member can update
      // their own slot in memberProfiles (for display-name resolution).
      allow update: if request.auth != null
                    && (resource.data.acl[request.auth.uid] == 'owner'
                        || resource.data.acl[request.auth.uid] == 'admin'
                        || isMemberSelfProfileUpdate());
      // Only the original owner can delete the workspace (soft delete in practice).
      allow delete: if request.auth != null
                    && resource.data.acl[request.auth.uid] == 'owner';
    }

    // ─── Projects ───────────────────────────────────────────────────────────
    match /projects/{projectId} {
      allow read:   if isOwner(resource)
                    || (request.auth != null && request.auth.uid in resource.data.members)
                    || isWorkspaceMember(resource.data.workspaceId);
      allow create: if isCreatingOwn() && isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isOwner(resource)
                    || canEditProject(projectId)
                    || canEditWorkspace(resource.data.workspaceId)
                    || isClaimingInvite(projectId);
      allow delete: if isOwner(resource)
                    || hasProjectRole(projectId, 'admin')
                    || isWorkspaceAdmin(resource.data.workspaceId);
    }

    // ─── Tasks ──────────────────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read:   if isOwner(resource)
                    || isWorkspaceMember(resource.data.workspaceId)
                    || (resource.data.projectId is string && isProjectMember(resource.data.projectId));
      // Create allowed when the creator is a workspace member of the target
      // workspace, OR is a member of the project the task is being added to.
      // The project-member branch is what lets a recipient of a SHARED
      // project add tasks even though they're not in the project's workspace.
      allow create: if isCreatingOwn()
                    && (isWorkspaceMember(request.resource.data.workspaceId)
                        || (request.resource.data.projectId is string
                            && isProjectMember(request.resource.data.projectId)));
      allow update: if isOwner(resource)
                    || canEditWorkspace(resource.data.workspaceId)
                    || (resource.data.projectId is string && canEditProject(resource.data.projectId));
      allow delete: if isOwner(resource)
                    || isWorkspaceAdmin(resource.data.workspaceId)
                    || (resource.data.projectId is string && hasProjectRole(resource.data.projectId, 'admin'));
    }

    // ─── Activities ─────────────────────────────────────────────────────────
    match /activities/{activityId} {
      allow read:   if isOwner(resource)
                    || isWorkspaceMember(resource.data.workspaceId)
                    || (resource.data.projectId is string && isProjectMember(resource.data.projectId));
      // Same as tasks: workspace member OR project member of the target.
      allow create: if isCreatingOwn()
                    && (isWorkspaceMember(request.resource.data.workspaceId)
                        || (request.resource.data.projectId is string
                            && isProjectMember(request.resource.data.projectId)));
      allow update: if isOwner(resource)
                    || canEditWorkspace(resource.data.workspaceId)
                    || (resource.data.projectId is string && canEditProject(resource.data.projectId));
      allow delete: if isOwner(resource)
                    || isWorkspaceAdmin(resource.data.workspaceId)
                    || (resource.data.projectId is string && hasProjectRole(resource.data.projectId, 'admin'));
    }

    // ─── Project invites (kept from v9) ─────────────────────────────────────
    function isClaimingInvite(projectId) {
      let inviteId = request.resource.data.lastClaimInviteId;
      let inv = inviteId is string && exists(/databases/$(database)/documents/invites/$(inviteId))
                ? get(/databases/$(database)/documents/invites/$(inviteId)).data
                : null;
      return request.auth != null
        && inv != null
        && inv.projectId == projectId
        && inv.revoked != true
        && (!('expiresAt' in inv.keys()) || inv.expiresAt == null || inv.expiresAt > request.time)
        && inv.role == request.resource.data.acl[request.auth.uid]
        && request.resource.data.acl[request.auth.uid] is string
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.size() == resource.data.members.size() + 1
        && request.resource.data.userId  == resource.data.userId
        && request.resource.data.name    == resource.data.name
        && request.resource.data.deleted == resource.data.deleted;
    }

    match /invites/{inviteId} {
      allow read:   if request.auth != null;
      allow create: if isCreatingOwn();
      allow update: if isOwner(resource) ||
                       (request.auth != null
                        && request.resource.data.userId    == resource.data.userId
                        && request.resource.data.projectId == resource.data.projectId
                        && request.resource.data.role      == resource.data.role
                        && request.resource.data.revoked   == resource.data.revoked);
      allow delete: if isOwner(resource);
    }

    // ─── Templates ──────────────────────────────────────────────────────────
    match /templates/{templateId} {
      allow read:   if isOwner(resource) || isWorkspaceMember(resource.data.workspaceId);
      allow create: if isCreatingOwn() && isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isOwner(resource) || canEditWorkspace(resource.data.workspaceId);
      allow delete: if isOwner(resource) || isWorkspaceAdmin(resource.data.workspaceId);
    }

    // ─── Goals (strategic-plan one-pagers, workspace-scoped) ────────────────
    match /goals/{goalId} {
      allow read:   if isOwner(resource) || isWorkspaceMember(resource.data.workspaceId);
      allow create: if isCreatingOwn() && isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isOwner(resource) || canEditWorkspace(resource.data.workspaceId);
      allow delete: if isOwner(resource) || isWorkspaceAdmin(resource.data.workspaceId);
    }

    // ─── Task comments ──────────────────────────────────────────────────────
    match /taskComments/{commentId} {
      // Read / create are extended to project members so recipients of a
      // SHARED project can see and add comments on its tasks even though
      // they're not in the project's workspace.
      allow read:   if isOwner(resource)
                    || isWorkspaceMember(resource.data.workspaceId)
                    || (resource.data.projectId is string && isProjectMember(resource.data.projectId));
      allow create: if isCreatingOwn()
                    && (isWorkspaceMember(request.resource.data.workspaceId)
                        || (request.resource.data.projectId is string
                            && isProjectMember(request.resource.data.projectId)));
      allow update: if isOwner(resource);
      allow delete: if isOwner(resource) || isWorkspaceAdmin(resource.data.workspaceId);
    }

    // ─── Chat: conversations + messages ─────────────────────────────────────
    // A conversation is a closed group: only its members may read or write it,
    // and it must live in a workspace the creator belongs to. Messages inherit
    // access from their conversation's member list.
    match /conversations/{conversationId} {
      allow read:   if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
                    && request.resource.data.createdByUserId == request.auth.uid
                    && request.auth.uid in request.resource.data.members
                    && isWorkspaceMember(request.resource.data.workspaceId);
      // Any current member may update (send → last-message preview, read
      // markers, rename, add members). Membership can't be emptied to lock out.
      allow update: if request.auth != null && request.auth.uid in resource.data.members;
      allow delete: if false;
    }

    match /messages/{messageId} {
      allow read:   if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.members;
      allow create: if request.auth != null
                    && request.resource.data.senderId == request.auth.uid
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(request.resource.data.conversationId)).data.members;
      allow update, delete: if request.auth != null && resource.data.senderId == request.auth.uid;
    }

    // ─── Saved views (personal-per-workspace) ───────────────────────────────
    match /savedViews/{viewId} {
      allow read:   if isOwner(resource);
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner(resource);
    }

    // ─── Presence (open to all authenticated, writes by owner only) ─────────
    match /presence/{docId} {
      allow read:   if request.auth != null;
      allow create: if isCreatingOwn();
      allow update: if isOwner(resource);
      allow delete: if isOwner(resource);
    }

    // ─── Webhooks (workspace-scoped admin tool) ─────────────────────────────
    match /webhooks/{hookId} {
      allow read:   if isOwner(resource) || isWorkspaceAdmin(resource.data.workspaceId);
      allow create: if isCreatingOwn() && isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isOwner(resource) || isWorkspaceAdmin(resource.data.workspaceId);
      allow delete: if isOwner(resource) || isWorkspaceAdmin(resource.data.workspaceId);
    }

    // ─── Legacy categories (unused) ─────────────────────────────────────────
    match /categories/{categoryId} {
      allow read:   if isOwner(resource);
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner(resource);
    }

    // ─── Companies (billing/admin construct that owns an Anthropic key) ────
    // Each user belongs to at most one company (users/{uid}.companyId). AI
    // calls made by any company member use the company's API key, so an
    // admin can budget Anthropic spend per company. Only superadmins can
    // create / edit / delete companies; company members can read just their
    // own company doc (to fetch the shared key client-side).
    function isMyCompany(companyId) {
      return request.auth != null
          && companyId is string
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('companyId', '') == companyId;
    }
    match /companies/{companyId} {
      allow read:   if isApprovedSuperadmin() || isMyCompany(companyId);
      allow create, update, delete: if isApprovedSuperadmin();
    }

    // ─── Users (approval-gated access control) ──────────────────────────────
    // Each authenticated user has a doc at users/{uid} carrying their status
    // (pending | approved | rejected) and role (user | superadmin).
    match /users/{userId} {
      // Users can always read their own profile (so the auth gate can fetch
      // status on sign-in). Approved superadmins can read all profiles to
      // power the User Management UI.
      allow read: if request.auth != null
                  && (request.auth.uid == userId || isApprovedSuperadmin());

      // First-time profile creation on sign-in. The user creates their own
      // doc; status must start as 'pending' (role 'user') unless the email
      // matches the hardcoded superadmin list — in which case they may
      // self-create as approved superadmin.
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.email == request.auth.token.email
                    && (
                      (request.resource.data.status == 'pending'
                        && request.resource.data.role == 'user')
                      ||
                      (request.resource.data.status == 'approved'
                        && request.resource.data.role == 'superadmin'
                        && isSuperadminEmail(request.auth.token.email))
                    );

      // Users can update their own profile (display name, photo) but cannot
      // change their own status or role. Superadmins can update any profile.
      allow update: if request.auth != null
                    && (
                      isApprovedSuperadmin()
                      ||
                      (request.auth.uid == userId
                        && request.resource.data.status == resource.data.status
                        && request.resource.data.role   == resource.data.role
                        && request.resource.data.email  == resource.data.email)
                    );

      // No deletes — historical records are kept.
      allow delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
