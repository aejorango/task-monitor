// Firestore Security Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(resource) {
      return request.auth != null
          && request.auth.uid == resource.data.userId;
    }

    function isCreatingOwn() {
      return request.auth != null
          && request.auth.uid == request.resource.data.userId;
    }

    // True if the requester appears in the project's members array. Used for
    // ACL-aware reads on projects + cascading to tasks/activities/comments
    // that reference projectId.
    function isProjectMember(projectId) {
      return request.auth != null
          && projectId is string
          && exists(/databases/$(database)/documents/projects/$(projectId))
          && request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.members;
    }
    function hasProjectRole(projectId, role) {
      return request.auth != null
          && projectId is string
          && exists(/databases/$(database)/documents/projects/$(projectId))
          && get(/databases/$(database)/documents/projects/$(projectId)).data.acl[request.auth.uid] == role;
    }
    function canEditProject(projectId) {
      return hasProjectRole(projectId, 'admin') || hasProjectRole(projectId, 'editor');
    }

    match /tasks/{taskId} {
      allow read:   if isOwner(resource) || (resource.data.projectId is string && isProjectMember(resource.data.projectId));
      allow create: if isCreatingOwn();
      allow update: if isOwner(resource) || (resource.data.projectId is string && canEditProject(resource.data.projectId));
      allow delete: if isOwner(resource) || (resource.data.projectId is string && hasProjectRole(resource.data.projectId, 'admin'));
    }

    match /activities/{activityId} {
      allow read:   if isOwner(resource) || (resource.data.projectId is string && isProjectMember(resource.data.projectId));
      allow create: if isCreatingOwn();
      allow update: if isOwner(resource) || (resource.data.projectId is string && canEditProject(resource.data.projectId));
      allow delete: if isOwner(resource) || (resource.data.projectId is string && hasProjectRole(resource.data.projectId, 'admin'));
    }

    match /projects/{projectId} {
      // Owners always have full access. Shared members read it via membership.
      allow read:   if isOwner(resource) || (request.auth != null && request.auth.uid in resource.data.members);
      allow create: if isCreatingOwn();
      // Updates: owner, admins, editors (no acl change), or a signed-in user
      // who is claiming a valid invite link (adds only themselves to acl/members).
      allow update: if isOwner(resource) ||
                       (request.auth != null
                        && request.auth.uid in resource.data.acl
                        && (resource.data.acl[request.auth.uid] == 'admin'
                            || (resource.data.acl[request.auth.uid] == 'editor'
                                && request.resource.data.acl == resource.data.acl
                                && request.resource.data.members == resource.data.members))) ||
                       isClaimingInvite(projectId);
      allow delete: if isOwner(resource);
    }

    // Self-claim rule: a signed-in user can add themselves to acl + members
    // ONLY when:
    //   • The write includes a `lastClaimInviteId` matching a real invite.
    //   • The invite's projectId matches this project, isn't revoked or expired.
    //   • The role being granted matches the invite.
    //   • Only the requester's uid is being added to acl + members.
    //   • The project's identity fields (userId, name, deleted) are unchanged.
    function isClaimingInvite(projectId) {
      let inviteId = request.resource.data.lastClaimInviteId;
      let inv = inviteId is string && exists(/databases/$(database)/documents/invites/$(inviteId))
                ? get(/databases/$(database)/documents/invites/$(inviteId)).data
                : null;
      return request.auth != null
        && inv != null
        && inv.projectId == projectId
        && inv.revoked != true
        && (!('expiresAt' in inv.keys()) || inv.expiresAt == null || inv.expiresAt > request.time)
        && inv.role == request.resource.data.acl[request.auth.uid]
        && request.resource.data.acl[request.auth.uid] is string
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.size() == resource.data.members.size() + 1
        && request.resource.data.userId  == resource.data.userId
        && request.resource.data.name    == resource.data.name
        && request.resource.data.deleted == resource.data.deleted;
    }

    match /invites/{inviteId} {
      // Anyone signed in can read an invite (the URL is the secret).
      allow read:   if request.auth != null;
      allow create: if isCreatingOwn();
      // Owner can update / revoke. Signed-in claimers can update only the
      // claims array (other fields locked) so they can record their claim.
      allow update: if isOwner(resource) ||
                       (request.auth != null
                        && request.resource.data.userId    == resource.data.userId
                        && request.resource.data.projectId == resource.data.projectId
                        && request.resource.data.role      == resource.data.role
                        && request.resource.data.revoked   == resource.data.revoked);
      allow delete: if isOwner(resource);
    }

    match /templates/{templateId} {
      allow read:   if isOwner(resource);
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner(resource);
    }

    match /taskComments/{commentId} {
      allow read:   if isOwner(resource);
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner(resource);
    }

    match /savedViews/{viewId} {
      allow read:   if isOwner(resource);
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner(resource);
    }

    match /presence/{docId} {
      // Anyone authenticated can read presence — used by collaborators to see
      // who else is viewing a task. Writes restricted to the owner.
      allow read:   if request.auth != null;
      allow create: if isCreatingOwn();
      allow update: if isOwner(resource);
      allow delete: if isOwner(resource);
    }

    match /webhooks/{hookId} {
      allow read:   if isOwner(resource);
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner(resource);
    }

    match /categories/{categoryId} {
      allow read:   if isOwner(resource);
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner(resource);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
