# Copy this file to ".env" (no "example" suffix) and fill in real values.
# Get all six values from Firebase Console → Project settings → Your apps → Web app config.
#
# IMPORTANT: every variable MUST start with VITE_ or Vite won't expose it.
# IMPORTANT: never commit the real .env — it's in .gitignore for a reason.

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456
